# Django
DJANGO_SETTINGS_MODULE=attendance_system.settings.development
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_here

# Database (MySQL)
DB_NAME=attendance_dbs
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage
MEDIA_ROOT=./media
IMAGE_STORAGE_PATH=./media/faces

# ML
FACE_MATCH_THRESHOLD=0.68
IMAGE_QUALITY_THRESHOLD=0.5
DEEPFACE_MODEL=ArcFace
DEEPFACE_DETECTOR=retinaface
DEEPFACE_DISTANCE=cosine

# ChromaDB
CHROMADB_PATH=./chromadb_store

# Production only
# ALLOWED_HOSTS=yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# SENTRY_DSN=
